{
  "expo": {
    "name": "MaxLinify",
    "slug": "maxlinify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "maxlinify",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maxlinify.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.maxlinify.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpg",
        "backgroundColor": "#0e0e0e"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-av",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e0e0e",
          "image": "./assets/images/icon.jpg",
          "imageWidth": 100
        }
      ]
    ],
    "newArchEnabled": true,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "746cdecc-2f8e-4c0d-b541-1c4b732d3215"
      }
    },
    "owner": "maxlin123"
  }
}
